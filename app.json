{
  "expo": {
    "name": "SnapAct",
    "slug": "snapact",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapact.app",
      "infoPlist": {
        "NSCameraUsageDescription": "SnapAct needs camera access to scan medicines, menus, bills, and documents.",
        "NSMicrophoneUsageDescription": "SnapAct uses the microphone for voice assistant features.",
        "NSLocationWhenInUseUsageDescription": "SnapAct uses location to provide locally relevant bill complaint URLs.",
        "NSSpeechRecognitionUsageDescription": "SnapAct uses speech recognition for voice commands."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.snapact.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "SnapAct needs camera access to scan and analyze content for you.",
          "microphonePermission": "SnapAct uses the microphone for voice assistant features.",
          "recordAudioAndroid": true
        }
      ],
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "newArchEnabled": false
          },
          "ios": {
            "newArchEnabled": false
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "83839864-a5f2-47e2-ae2b-2a34f5c4bcba"
      }
    }
  }
}
